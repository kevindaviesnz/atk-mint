require('dotenv').config();
const fs = require('fs');
const path = require('path');
const http = require('http');

// Autarky Mark VCS CLI
const command = process.argv[2];
const args = process.argv.slice(3);

function initWallet() {
    // ⚠️ Drop your existing 'init' cryptographic and AES encryption logic here
    console.log("[Mark VCS] Initializing...");
}

function commitCode(message) {
    // ⚠️ Drop your existing 'commit' hashing, signing, and PoW logic here
    console.log("[Mark VCS] Committing...");
}

function showLog() {
    // ⚠️ Drop your existing 'log' ledger retrieval logic here
    console.log("[Mark VCS] Fetching Ledger History...");
}

function checkoutCommit(hash) {
    // ⚠️ Drop your existing 'checkout' state extraction logic here
    console.log(`[Mark VCS] Checking out ${hash}...`);
}

function showAddress() {
    try {
        if (!fs.existsSync('wallet.json')) {
            console.log("❌ wallet.json is missing. Run 'node mark.js init' first.");
            return;
        }
        
        const walletData = JSON.parse(fs.readFileSync('wallet.json', 'utf8'));
        
        console.log("\n📬 Your Autarky Public Address:");
        console.log("--------------------------------------------------");
        console.log(walletData.publicKey);
        console.log("--------------------------------------------------\n");
        console.log("Share this string to receive atk-mint computational credits.");
        
    } catch (error) {
        console.log("❌ Error reading wallet.json:", error.message);
    }
}

function checkBalance() {
    try {
        if (!fs.existsSync('wallet.json')) {
            console.log("❌ wallet.json is missing. Run 'node mark.js init' first.");
            return;
        }

        const walletData = JSON.parse(fs.readFileSync('wallet.json', 'utf8'));
        const publicKey = walletData.publicKey;

        console.log(`[Mark VCS] Querying network for address: ${publicKey.substring(0, 16)}...`);

        // Ping the local node for the balance
        http.get(`http://localhost:3000/balance/${publicKey}`, (res) => {
            let data = '';

            res.on('data', (chunk) => {
                data += chunk;
            });

            res.on('end', () => {
                if (res.statusCode === 200) {
                    const response = JSON.parse(data);
                    console.log("\n💰 Available Balance:");
                    console.log("--------------------------------------------------");
                    console.log(`   ${response.balance} atk-mint (Computational Gas)`);
                    console.log("--------------------------------------------------\n");
                } else {
                    console.log(`❌ Network returned an error: ${res.statusCode} - ${data}`);
                }
            });
        }).on('error', (err) => {
            console.log("❌ Failed to connect to the Autarky node.");
            console.log("   Make sure 'node server.js' is running in another terminal window.");
        });

    } catch (error) {
        console.log("❌ Error reading wallet.json:", error.message);
    }
}

// --------------------------------------------------
// Command Router
// --------------------------------------------------
switch (command) {
    case 'init':
        initWallet();
        break;
    case 'commit':
        commitCode(args[0]);
        break;
    case 'log':
        showLog();
        break;
    case 'checkout':
        checkoutCommit(args[0]);
        break;
    case 'address':
        showAddress();
        break;
    case 'balance':
        checkBalance();
        break;
    default:
        console.log("Autarky Mark VCS");
        console.log("Usage: node mark.js <command> [args]\n");
        console.log("Commands:");
        console.log("  init      - Generate a new sovereign identity");
        console.log("  commit    - Anchor code state to the blockchain");
        console.log("  log       - View immutable ledger history");
        console.log("  checkout  - Verify and extract a historical commit");
        console.log("  address   - Display your public receiving address");
        console.log("  balance   - Query the network for your atk-mint funds");
        break;
}