#!/bin/bash

# --- Path Logic ---
# On your Mac, we want this to point to your Dev folder.
# Inside Docker, we want it to point to /app.
if [ -d "/app" ]; then
    PROJECT_DIR="/app"
else
    PROJECT_DIR="/Users/kevindavies/Development/AI/atk-mint"
fi

# Change to the project directory so Node can find wallet.json
cd "$PROJECT_DIR" || { echo "❌ Directory not found at $PROJECT_DIR"; exit 1; }

case "$1" in
  balance)
    node mark.js balance
    ;;
  address)
    node mark.js address
    ;;
  send)
    if [ -z "$2" ] || [ -z "$3" ]; then
      echo "Usage: atk-mint send <address> <amount>"
    else
      # Calling the 'send' script wrapper
      ./send "$2" "$3"
    fi
    ;;
  mine)
    # Starts your universal miner.sh loop
    ./miner.sh "${2:-"Kevins-Rig"}"
    ;;
  *)
    echo "Usage: atk-mint {balance|address|send|mine}"
    echo "Example: atk-mint send <address> 1000"
    exit 1
    ;;
esac