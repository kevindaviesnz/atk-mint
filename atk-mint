#!/bin/bash

# 1. Identify where mark.js lives
DIR="$(cd "$(dirname "${BASH_SOURCE}")" && pwd)"
if [ ! -f "$DIR/mark.js" ]; then
    DIR="."
fi

COMMAND=$1
ARG2=$2

# 2. THE ROUTER LOGIC
if [ "$COMMAND" == "mine" ]; then
    # ONLY enter the continuous loop if the user specifically typed 'mine'
    MESSAGE=${ARG2:-"Kevins-Rig"}
    echo "========================================="
    echo "⛏️  ATK-Mint CONTINUOUS CLOUD RIG"
    echo "💬 Message: $MESSAGE"
    echo "🌐 Vault: https://atk-mint-vault.duckdns.org"
    echo "========================================="
    
    while true; do
        echo "⚒️  Starting mining attempt..."
        node "$DIR/mark.js" commit "$MESSAGE"
        echo ""
        echo "♻️  Cooling down (2s)..."
        sleep 2
    done

else
    # For EVERY OTHER command (init, balance, address, etc.)
    # Just pass the arguments directly to Node and exit.
    node "$DIR/mark.js" "$@"
fi